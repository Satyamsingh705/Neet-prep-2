### Local development environment variables (do NOT commit secrets)
# Copy this file to `.env.local` and fill with local values.

# Use a local or pooled DB URL for development. For Supabase use the pooled runtime URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Optional direct DB URL for admin/one-time tasks
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Supabase storage (optional for local dev)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="questions"

# Session secrets - use long random strings
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"
STUDENT_SESSION_SECRET="replace-with-a-long-random-secret"

# Optional fallback token for Vercel Blob local testing
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
